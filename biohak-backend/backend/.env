# BioHAK Wellness API — Environment Variables
# Copy this to .env and fill in your values

# Server
PORT=5000
NODE_ENV=development
FRONTEND_URL=https://biohakwellness.vercel.app

# Database (Supabase PostgreSQL)
DATABASE_URL=postgresql://postgres:[Bobbyd@mz06_1993]@db.xdrbeycabjprvcicezwj.supabase.co:5432/postgres

# JWT
JWT_SECRET=your_super_secret_jwt_key_min_32_chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your_refresh_secret_key_min_32_chars
JWT_REFRESH_EXPIRES_IN=7d

# Razorpay
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret

# Email (SendGrid)
SENDGRID_API_KEY=SG.xxxxx
EMAIL_FROM=hello@biohakwellness.com
EMAIL_FROM_NAME=BioHAK Wellness

# Admin
ADMIN_EMAIL=admin@biohakwellness.com

# Free shipping threshold (INR)
FREE_SHIPPING_THRESHOLD=1000
SHIPPING_CHARGE=99
